# ==========================================
# Life-OS Environment Variables
# ==========================================

# 1. OpenRouter (API Key for access to Claude/GPT-4o)
OPENROUTER_API_KEY=sk-or-v1-...

# 2. Supabase Configuration (PostgreSQL + pgvector cloud database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# 3. Telegram Bot Configuration (From BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF
TELEGRAM_WEBHOOK_URL=https://telegram-webhook.your-domain.com

# 4. Ngrok Tunnel (For setting up the secure tunnel to localhost:8000)
NGROK_AUTHTOKEN=your_ngrok_token
NGROK_DOMAIN=your-static-domain.ngrok-free.app

# 5. Tailscale (Optional: if auth key is used for unattended install)
TAILSCALE_AUTH_KEY=tskey-auth-...

# 6. Finance (PDF Ingestion)
STATEMENT_DIRECTORY=./data/statements

# 7. Finnhub (For Stock/Market Data)
FINNHUB_API_KEY=...

# 8. Removed Google Calendar (Voice Memo Based Scheduling)

# 9. Xiaomi Mi Fitness (For Sleep and Workout Data)
XIAOMI_EMAIL=your_email@example.com
XIAOMI_PASSWORD=your_password
XIAOMI_REGION=eu

# 10. Ollama Local Endpoint (Default should be localhost:11434)
OLLAMA_HOST=http://localhost:11434

# 11. Supabase Auth (For Next.js Frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# 12. Redis Endpoint (For LangGraph State/Memory Cache)
REDIS_URL=redis://localhost:6379

# 11. LangSmith Observability
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langchain_api_key


